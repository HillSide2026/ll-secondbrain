	<array>
		<string>/Applications/Xcode.app/Contents/Developer/Library/Frameworks/Python3.framework/Versions/3.9/bin/python3</string>
		<string>/Users/matthewlevine/Repos/ll-secondbrain_fresh/scripts/hourly_inbox_triage.py</string>
