<!--
  Hourly Inbox Triage Agent — launchd schedule
  Runs scripts/hourly_inbox_triage.py every hour, 09:00–17:00, Mon–Fri.

  Install:
    cp scripts/launchd/ca.levinelaw.ml2.hourly-inbox-triage.plist \
       ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/ca.levinelaw.ml2.hourly-inbox-triage.plist

  Unload:
    launchctl unload ~/Library/LaunchAgents/ca.levinelaw.ml2.hourly-inbox-triage.plist

  Run manually:
    launchctl start ca.levinelaw.ml2.hourly-inbox-triage

  Logs:
    06_RUNS/logs/hourly_inbox_triage/launchd.stdout.log
    06_RUNS/logs/hourly_inbox_triage/launchd.stderr.log
    06_RUNS/INBOX_TRIAGE/logs/hourly_triage_run.ndjson  (per-thread decisions)
    06_RUNS/INBOX_TRIAGE/state/last_run.json            (run state)
-->
