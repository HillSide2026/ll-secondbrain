# =============================================================================
# ll-secondbrain environment variable schema
# =============================================================================
# This file defines ALL required variables. It contains NO real values.
# Copy to .env and populate from the canonical secret store (see docs/ENVIRONMENT.md).
# .env is gitignored and must never be committed.
# =============================================================================

# --- Azure / Microsoft Graph ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- SharePoint sites ---
SHAREPOINT_LEGALMATTERS_SITE=levinellp.sharepoint.com/sites/LegalMatters
SHAREPOINT_ONBOARDING_SITE=levinellp.sharepoint.com/sites/Documentation

# --- Graph API configuration ---
GRAPH_API_BASE=https://graph.microsoft.com/v1.0

# --- Google OAuth (Gmail integration) ---
GOOGLE_OAUTH_CLIENT_PATH=
GOOGLE_OAUTH_TOKEN_PATH=

# --- Optional runtime configuration ---
LOG_LEVEL=INFO
